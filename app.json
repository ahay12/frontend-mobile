{
  "expo": {
    "name": "Edlink Sentiment",
    "slug": "skripsi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "edlink-sentiment",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.edlinksentiment.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#4f46e5"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "89630d03-21cc-4eed-b9b6-7aa268b3e08a"
      }
    },
    "owner": "acndigital",
    "plugins": [
      "expo-font"
    ]
  }
}
